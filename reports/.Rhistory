import yaml
from pathlib import Path
with open(Path('../eval-app/src/evaluator/data/toxpipe_eval_info/config/raw/providers.yaml')) as fp:
d = yaml.safe_load(fp)
for model in d['base-model']['providers']:
print(f'- {model['label']}')
